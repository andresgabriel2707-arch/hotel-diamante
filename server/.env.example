# 🔐 VARIABLES DE ENTORNO - Hotel Diamante
# 
# Copia este archivo como ".env" en la carpeta "server/"
# NUNCA commits .env a git (está en .gitignore)

# JWT Secret - Cambiar a un valor muy largo y aleatorio en producción
# Puedes generar uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=diamante_secret_2026_development_only_CAMBIAR_EN_PRODUCCION

# Entorno
NODE_ENV=development

# Puerto del servidor
PORT=3000

# CORS - Dominios permitidos (separados por coma)
# En desarrollo: * (todos)
# En producción: https://tudominio.com,https://www.tudominio.com
CORS_ORIGINS=*

# Configuración de BD (si migramos de NeDB)
# DATABASE_URL=mongodb://localhost:27017/hotel_diamante
# o
# DATABASE_URL=postgresql://user:pass@localhost:5432/hotel_diamante

# Email (opcional - para verificación futura)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu_correo@gmail.com
# SMTP_PASS=tu_contraseña_aplicacion
# SMTP_FROM=noreply@hoteldiamante.com
